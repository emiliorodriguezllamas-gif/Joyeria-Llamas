{
  "name": "llamas-joyeria",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:exe": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.joyeriallamas.erp",
