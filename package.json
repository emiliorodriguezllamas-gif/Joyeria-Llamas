      "icon": "public/favicon.ico"
    }
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "dexie": "^4.4.2",
    "dexie-export-import": "^4.4.0",
    "dexie-react-hooks": "^4.4.0",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
